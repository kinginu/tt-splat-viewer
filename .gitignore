# Rust
/target
**/*.rs.bk

# wasm / web build output — built in CI and deployed to GitHub Pages (.github/workflows/pages.yml).
# web/index.html + web/sample.ply are tracked; the wasm/js are generated, not committed.
/pkg
/dist
/web/*.wasm
/web/*.js

# scenes & generated renders (large / reproducible)
*.ply
!/web/sample.ply
/scenes
/out
*.png
!docs/**/*.png

# generated validation artifacts (reproducible via validation/*.py; only the .py scripts are tracked)
/validation/*.json
# Cargo.lock IS tracked so the Pages CI build is reproducible (and pins wasm-bindgen for the CLI).

# editor / os
.DS_Store
.idea/
.vscode/
