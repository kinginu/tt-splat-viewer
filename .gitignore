# Rust
/target
**/*.rs.bk

# wasm / web build output (regenerate with the wasm-bindgen step in CLAUDE.md; index.html is tracked)
/pkg
/dist
/web/*.wasm
/web/*.js

# scenes & generated renders (large / reproducible)
*.ply
/scenes
/out
*.png
!docs/**/*.png

# generated validation artifacts (reproducible via validation/*.py; only the .py scripts are tracked)
/validation/*.json
/Cargo.lock

# editor / os
.DS_Store
.idea/
.vscode/
