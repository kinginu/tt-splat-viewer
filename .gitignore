# Rust
/target
**/*.rs.bk

# wasm / web build output
/pkg
/dist
# NOTE: web/ (wasm+js+sample.ply) IS tracked so a Rust-less machine can `git pull` + static-serve it.
# Regenerate the wasm/js with the wasm-bindgen step in CLAUDE.md and re-commit them after code changes.

# scenes & generated renders (large / reproducible)
*.ply
!/web/sample.ply
/scenes
/out
*.png
!docs/**/*.png

# generated validation artifacts (reproducible via validation/*.py; only the .py scripts are tracked)
/validation/*.json
/Cargo.lock

# editor / os
.DS_Store
.idea/
.vscode/
